{
    "name": "bangbangda/wecomaibot",
    "description": "企业微信 AI 机器人 PHP SDK — 基于 WebSocket 长连接，免回调地址配置",
    "type": "library",
    "license": "MIT",
    "keywords": ["wecom", "wechat-work", "ai-bot", "websocket", "workerman"],
    "homepage": "https://github.com/bangbangda/wecomaibot",
    "authors": [
        {
            "name": "bangbangda",
            "homepage": "https://github.com/bangbangda"
        }
    ],
    "require": {
        "php": ">=8.1",
        "workerman/workerman": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "WeComAiBot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WeComAiBot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WeComAiBot\\Laravel\\WeComAiBotServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
